# --- Server ---
NODE_ENV=production
PORT=4000
CORS_ORIGIN=https://your-frontend-domain.com
SELF_PING_URL= # optional: set to this service's own public URL to prevent Render free-tier spin-down

# --- Database (Render Postgres connection string) ---
DATABASE_URL=postgresql://user:password@host:5432/venuxpay
DB_SSL=true

# --- Auth ---
# Generate with: openssl rand -base64 48
JWT_SECRET=
JWT_EXPIRES_IN=15m

# --- Secrets encryption (for provider API keys stored in the database) ---
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=

# --- Payment gateway webhook verification ---
# These are only used as a fallback identifier; actual keys are stored
# encrypted in the database via the admin panel (Settings > Providers).
PAYSTACK_SECRET_KEY=
MONNIFY_SECRET_KEY=

# --- First admin account (used once by `npm run db:seed`) ---
SEED_ADMIN_EMAIL=admin@venuxpay.com
SEED_ADMIN_PASSWORD=change-this-immediately
